    <script language="javascript">
        var saniye
        var dakika
        var timerID = null
        var timerRunning = false
        var delay = 1000
        mf = (document.getElementById);
        ns = (document.layers);
        ie = (document.all);
        function hatagoster(e, b, x) {
            //sgMsgbox("E", "Sistem Hatası", x + ":" + e.responseText, true, true, false, "TF", 5);
            sgMsgbox("E", "Sistem Hatası", x + ":İşlem Sırasında bir hata oluştu", true, true, false, "TF", 5);
            $("#msgBoxMaster").hide();
            $("#scriptkontrol").val('0');
        }
        function InitializeTimer() {
            dakika = 9
            saniye = 59
            SureBitis()
            SureBaslat()
        }
        function SureBitis() {
            if (timerRunning)
                clearTimeout(timerID)
            timerRunning = false
        }
        function SureBaslat() {
            if (dakika < 0) {
                SureBitis()
                alert("10 dakika süreyle hiç bir işlem yapmadığınız için bağlantınız kesildi.Devam etmek için sisteme yeniden giriniz.")
            }
            else {
                if (saniye < 10) {
                    if (document.all)
                        document.all["txtBaglantiSonu"].value = "0" + dakika + ":0" + saniye;
                    else if (document.getElementById)
                        document.getElementById("txtBaglantiSonu").value = "0" + dakika + ":0" + saniye;
                }
                else {
                    if (document.all)
                        document.all["txtBaglantiSonu"].value = "0" + dakika + ":" + saniye;
                    else if (document.getElementById)
                        document.getElementById("txtBaglantiSonu").value = "0" + dakika + ":" + saniye;
                }

                saniye = saniye - 1
                if (saniye == 0) {
                    dakika = dakika - 1
                    saniye = 59
                }
                timerRunning = true
                timerID = self.setTimeout("SureBaslat()", delay)
            }
        }
        if (ns || ie || mf) window.onload = InitializeTimer;

    </script>

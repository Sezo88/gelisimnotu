        ReturnRecord: function (msg, funcparameter) {
            InitializeTimer();
            this.hata.hatamesaji = null;
            var readList = msg.d;
            if (typeof funcparameter === 'object') {
                $("#chartdiv").LoadingOverlay("hide", true);
                var self = this;

                if (funcparameter.nesneadi == this.formkontrol.subeler.id) {
                    if (readList.length == 1)
                        this.formkontrol.subeler.value = readList[0].eIndex;
                    ComboDoldur((new Object({ nesneadi: funcparameter.nesneadi, veri: readList, cmbType: "select2", bosekle: true, bosekleTekse: true, ilkeleman: "Sınıf Seçiniz" })));
                    LutfenBekleyinizButon("btnListele", false, " Listele ");
                    $("#" + funcparameter.nesneadi).select2().change(function (e) {
                        self.formkontrol.subeler.value = this.value;
                        self.ogrenciData = null;
                        self.TemaifadeOneriData = null;
                        self.editItem = null;
                        self.showForm = false;
                        self.getData = null;
                    });
                }
                else if (funcparameter.nesneadi == this.formkontrol.dersler.id) {
                    if (readList.length == 1)
                        this.formkontrol.dersler.value = readList[0].eIndex;
                    ComboDoldur((new Object({ nesneadi: funcparameter.nesneadi, veri: readList, cmbType: "select2", bosekle: true, bosekleTekse: true, ilkeleman: "Ders Seçiniz" })));

                        self.formkontrol.dersler.value = this.value;
                        self.ogrenciData = null;
                        self.editItem = null;
                        self.TemaifadeOneriData = null;
                        self.showForm = false;
                        self.getData = null;
                    });
                }

            }
            else {
                if (readList.error) {
                    if (readList.redirect) {
                        GotoPage(readList.url);
                    }
                    else {
                        $("#chartdiv").LoadingOverlay("hide", true);
                        this.hata.hatamesaji = readList.message;
                        this.hata.baslik = "Hata";
                        this.hata.hatatipi = 'danger';
                        this.showList = false;

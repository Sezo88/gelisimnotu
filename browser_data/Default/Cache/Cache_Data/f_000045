        PageCommonFunction: function (CommonParameter, funcparameter) {
            InitializeTimer();
            if (CommonParameter == "ModalPopupConfirm") {
                var islemparametresi = $('#hdnModalPopupConfirm').val();
                $('#hdnModalPopupConfirm').val("-1");
                if (funcparameter == "Yes") {
                    if (islemparametresi == "Kaydet") {
                        var self = this;
                        this.sendData = this.getData.flatMap(tema =>
                            tema.MADDELER.filter(madde => madde.MADDE_PUAN !== 0).map(madde => ({
                                temaid: tema.TEMA_ID,
                                maddeid: madde.MADDE_ID,
                                maddepuan: madde.MADDE_PUAN
                            }))
                        );
                        var secilenDonem = (this.selectedDonem != null && this.selectedDonem !== '') ? this.selectedDonem : (this.selectedDonemorjinal % 2 === 0 ? 1 : 2);

                        var Keyler = ["ogrenciId", "subekodu", "derskodu", "jsondata", "sinifno", "secilendonem", "aktifsinif"];
                        var Degerler = [this.editItem.OgrenciId, this.formkontrol.subeler.value, this.formkontrol.dersler.value, JSON.stringify(this.sendData), this.selectedSinif, secilenDonem, this.selectedSiniforjinal];
                        AjaxGonder(Keyler, Degerler, "-1", "Kaydet", "ReturnKaydet", "json");
                    }
                    else if (islemparametresi == "GelisimRaporu") {

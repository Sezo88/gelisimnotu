<script>
    var app2 = new Vue({
        el: "#subeozeti",
        data: {
            subeozeti: null,
            enableSelection:true,
        },

        methods: {
            barCssClass: function (tamamlanma) {

                if (tamamlanma == 100)
                    return "bg-success";
                else if (tamamlanma < 25)
                    return "bg-danger";
                else if (tamamlanma < 50)
                    return "bg-warning";
                else
                    return "";

            },
            OzetGoster: function () {
                if (app.formkontrol.subeler.value == app.formkontrol.subeler.kontrolDegeri) {
                    sgMsgbox("e", "Hata", "Şube Seçiniz", true, true, false, "TF", 5);
                }
                else {
                    var Keyler = ["subekodu"];
                    var Degerler = [app.formkontrol.subeler.value];
                    AjaxGonder(Keyler, Degerler, "-1", "GetMaarifSubeOzeti", "ReturnGetMaarifSubeOzeti", "json");
                }

            },
            ReturnRecord: function (msg, funcparameter) {
                InitializeTimer();
                app.hata.hatamesaji = null;
                var readList = msg.d;
                if (readList.error) {
                    if (readList.redirect) {
                        GotoPage(readList.url);
                    }
                    else {
                        $("#chartdiv").LoadingOverlay("hide", true);
                        app.hata.hatamesaji = readList.message;
                        app.hata.baslik = "Hata";
                        app.hata.hatatipi = 'danger';
                        app.showList = false;
                        if (readList.takvim == false) {
                            app.ogrenciData = null;
                            app.showForm = false;
                            app.editItem = null;
                            $("#IOMToolbarActive1_btnKaydet").attr("disabled", "disabled").removeAttr("onclick");
                        }
                    }
                }
                else {
                    $("#chartdiv").LoadingOverlay("hide", true);
                    if (funcparameter == "ReturnGetMaarifSubeOzeti") {
                        if (readList.message == "") {
                            sgMsgbox("e", "Hata", "Veri bulunamadı", true, true, false, "TF", 5); return;
                        }
                        const fectData = JSON.parse(JSON.parse(JSON.stringify(readList.message)));
                        const groupedData = fectData.reduce((acc, curr) => {
                            // Öğrenci grubu oluştur
                            const key = curr.OGRENCI_NO;
                            if (!acc[key]) {
                                acc[key] = {
                                    OGRENCI_NO: curr.OGRENCI_NO,
                                    OGRENCI_ID: curr.OGRENCI_ID,
                                    ADI_SOYADI: curr.ADI_SOYADI,
                                    DERSLER: []

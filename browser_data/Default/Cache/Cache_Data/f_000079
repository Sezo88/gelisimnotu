        window.location.href = '/giris.aspx';
    }
    function Dogrula() {
        /*debugger*/;
        console.log("!");
        let UyariMesaji = "";
         let sayfaAdi = window.location.pathname.split("/").pop().split(".")[0];
            let ilkUcKarakter = sayfaAdi.substring(0, 3);

        UyariMesaji = UyariMesaji + NumAlan($("#txtMebAnahtar").val(), "MEB Anahtar", 999999, 1, false);
        if ($("#txtMebAnahtar").val().length != 6)
            UyariMesaji += "MEB Anahtar kodu 6 haneli olmalıdır";

        if (UyariMesaji != "") {
            if ( !(ilkUcKarakter == 'IOK' || ilkUcKarakter == 'AOK') )
            {
                swal({
                    icon: "error",
                    text: UyariMesaji,
                    button: "Tamam",
                    type: "success",
                    allowEnterKey: true
                }).then(function (result) {
                    mebAnahtarControlShow();
                });
                $(".swal-button").focus();
            }
            else {
                 swal.fire({
                     icon: "error",
                     text: UyariMesaji,
                     button: "Tamam",
                     type: "success",
                     allowEnterKey: true
                 }).then(function (result) {
                     mebAnahtarControlShow();
                 });
                 $(".swal-button").focus();
           }
        }
        else {
            AjaxUserControl(["MebAnahtar", "benihatirla", "User_Name", "verification"], [$("#txtMebAnahtar").val(), "0", $("#hdnUserName").val(), $("#RaporEkranKodu").val()], "../../logineOkul.aspx", "MebAnahtar", "ReturnGetMebAnahtar", "json");
